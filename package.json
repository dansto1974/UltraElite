{
  "name": "ultra-elite",
  "private": true,
  "version": "1.0.21-beta",
  "scripts": {
    "check": "node tools/build/check.mjs",
    "check:fix": "node tools/build/check.mjs --fix",
    "audit:obsidian": "node tools/obsidian/index-knowledge.mjs --check && node tools/obsidian/audit-notes.mjs && node tools/obsidian/audit-local-skills.mjs && node tools/obsidian/audit-link-graph.mjs && node tools/obsidian/audit-release-flow.mjs",
    "collate:obsidian": "node tools/obsidian/collate-knowledge-notes.mjs --build",
    "index:obsidian": "node tools/obsidian/index-knowledge.mjs",
    "index:obsidian:check": "node tools/obsidian/index-knowledge.mjs --check",
    "audit:render-intent": "node tools/build/audit-render-intent.mjs",
    "audit:render-intent:strict": "node tools/build/audit-render-intent.mjs --strict",
    "models": "node tools/build/generate-model-library.mjs",
    "skins": "node tools/build/generate-bitmap-skins.mjs",
    "skins:force": "node tools/build/generate-bitmap-skins.mjs --force",
    "skins:recompress": "node tools/build/generate-bitmap-skins.mjs --recompress",
    "skins:recompress:dry": "node tools/build/generate-bitmap-skins.mjs --recompress --dry-run",
    "skin-templates": "node tools/build/generate-skin-templates.mjs",
    "build": "node tools/build/generate-model-library.mjs && node tools/build/generate-bitmap-skins.mjs && node tools/build/build-single-file.mjs",
    "bench:render": "node tools/render-bench/run-bench.mjs --serve=1 --batch=1 --models=all --qualities=full --iterations=80 --warmup=20 --settle-runs=3 --runs=3 --mode=solid --fx=ultra --lod=0 --scale=46 --json-out=tools/render-bench/reports/latest.json",
    "build:bench": "npm run build && npm run bench:render",
    "publish:site": "node tools/publish-site.mjs",
    "tools": "node tools/open-tool.mjs /tools/",
    "dev": "python3 -m http.server 8765",
    "dev:tools": "node tools/local-dev-server.mjs"
  }
}
